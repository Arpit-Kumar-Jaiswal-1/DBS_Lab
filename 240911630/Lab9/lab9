-- Q5: Function to return square of a number.
CREATE OR REPLACE FUNCTION square_num (p_num NUMBER)
RETURN NUMBER IS
BEGIN
    RETURN p_num * p_num;
END;
/

DECLARE
    v_result NUMBER;
BEGIN
    v_result := square_num(5);
    DBMS_OUTPUT.PUT_LINE('Square = ' || v_result);
END;
/
