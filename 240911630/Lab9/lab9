-- Q3: Procedure course_popular to find most popular course in a department.
CREATE OR REPLACE PROCEDURE course_popular (p_dept VARCHAR2) IS
    v_course_id course.course_id%TYPE;
    v_title course.title%TYPE;
BEGIN
    SELECT c.course_id, c.title
    INTO v_course_id, v_title
    FROM course c
    JOIN takes t ON c.course_id = t.course_id
    WHERE c.dept_name = p_dept
    GROUP BY c.course_id, c.title
    HAVING COUNT(t.ID) = (
        SELECT MAX(COUNT(*))
        FROM course c2
        JOIN takes t2 ON c2.course_id = t2.course_id
        WHERE c2.dept_name = p_dept
        GROUP BY c2.course_id
    );

    DBMS_OUTPUT.PUT_LINE('Most popular course in ' || p_dept || ': ' ||
                         v_course_id || ' ' || v_title);
END;
/

BEGIN
    FOR rec IN (SELECT DISTINCT dept_name FROM course) LOOP
        course_popular(rec.dept_name);
    END LOOP;
END;
/
