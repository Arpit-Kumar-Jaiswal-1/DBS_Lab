-- Q7: Package with procedure and function.
CREATE OR REPLACE PACKAGE dept_pkg IS
    PROCEDURE list_instructors (p_dept VARCHAR2);
    FUNCTION max_salary (p_dept VARCHAR2) RETURN NUMBER;
END dept_pkg;
/

CREATE OR REPLACE PACKAGE BODY dept_pkg IS
    PROCEDURE list_instructors (p_dept VARCHAR2) IS
    BEGIN
        FOR rec IN (SELECT name FROM instructor WHERE dept_name = p_dept) LOOP
            DBMS_OUTPUT.PUT_LINE(rec.name);
        END LOOP;
    END;

    FUNCTION max_salary (p_dept VARCHAR2) RETURN NUMBER IS
        v_salary NUMBER;
    BEGIN
        SELECT MAX(salary)
        INTO v_salary
        FROM instructor
        WHERE dept_name = p_dept;
        RETURN v_salary;
    END;
END dept_pkg;
/

BEGIN
    dept_pkg.list_instructors('&dept_name');
    DBMS_OUTPUT.PUT_LINE('Max salary = ' || dept_pkg.max_salary('&dept_name'));
END;
/
