-- Q2: Procedure which takes dept_name as input and lists instructors and courses.
CREATE OR REPLACE PROCEDURE dept_info (p_dept VARCHAR2) IS
BEGIN
    DBMS_OUTPUT.PUT_LINE('Instructors in ' || p_dept || ':');
    FOR rec IN (SELECT ID, name FROM instructor WHERE dept_name = p_dept) LOOP
        DBMS_OUTPUT.PUT_LINE(rec.ID || ' ' || rec.name);
    END LOOP;

    DBMS_OUTPUT.PUT_LINE('Courses in ' || p_dept || ':');
    FOR rec IN (SELECT course_id, title FROM course WHERE dept_name = p_dept) LOOP
        DBMS_OUTPUT.PUT_LINE(rec.course_id || ' ' || rec.title);
    END LOOP;
END;
/

BEGIN
    dept_info('&dept_name');
END;
/
