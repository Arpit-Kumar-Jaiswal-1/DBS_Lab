-- Q4: Procedure to list students and courses of a department.
CREATE OR REPLACE PROCEDURE dept_students_courses (p_dept VARCHAR2) IS
BEGIN
    DBMS_OUTPUT.PUT_LINE('Students in ' || p_dept || ':');
    FOR rec IN (SELECT ID, name FROM student WHERE dept_name = p_dept) LOOP
        DBMS_OUTPUT.PUT_LINE(rec.ID || ' ' || rec.name);
